<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gdpu.mapper.SysUserMapper">

    <resultMap id="BaseResultMap" type="com.gdpu.entity.SysUser">
            <id property="userId" column="user_id" />
            <result property="username" column="username" />
            <result property="password" column="password" />
            <result property="sex" column="sex" />
            <result property="address" column="address" />
            <result property="enabled" column="enabled" />
            <result property="accountNoExpired" column="account_no_expired" />
            <result property="credentialsNoExpired" column="credentials_no_expired" />
            <result property="accountNoLocked" column="account_no_locked" />
    </resultMap>

    <sql id="Base_Column_List">
        user_id,username,password,sex,address,enabled,
        account_no_expired,credentials_no_expired,account_no_locked
    </sql>
    <select id="findByUserName" resultType="com.gdpu.entity.SysUser">
        select <include refid="Base_Column_List"/> from sys_user where username = #{username}
    </select>
    <select id="findAuthenticationByUserId" resultType="java.lang.String">
        SELECT distinct sm.`code` CODE
        FROM sys_menu sm
                 JOIN sys_role_menu srm ON srm.mid = sm.id
                 JOIN sys_role_user sru ON sru.rid = srm.rid
        WHERE sru.uid = #{id}
          and sm.`code` is not null;
    </select>
</mapper>
